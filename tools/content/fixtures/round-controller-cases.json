[
  {
    "name": "controller starts with hud and tool state",
    "modeId": "hidden_object_demo",
    "steps": [],
    "expectedViewModel": {
      "hud": {
        "status": "playing",
        "foundCount": 0,
        "totalCount": 4,
        "score": 0
      }
    },
    "expectedToolState": {
      "hint": {
        "usesRemaining": 3,
        "cooldownRemainingSeconds": 0
      }
    }
  },
  {
    "name": "tap updates round and view model",
    "modeId": "hidden_object_demo",
    "steps": [
      {
        "type": "tap",
        "point": {
          "x": 330,
          "y": 860
        },
        "expectedRoundEvents": ["correctHit"],
        "expectedFeedbackPlans": [
          {
            "kind": "preset",
            "sourceEventType": "correctHit",
            "feedbackPresetId": "find_success",
            "targetId": "demo_pineapple_001"
          }
        ],
        "expectedViewModel": {
          "hud": {
            "score": 110,
            "foundCount": 1,
            "progress01": 0.25
          }
        }
      }
    ]
  },
  {
    "name": "hint emits tool event and tick cools down",
    "modeId": "hidden_object_demo",
    "steps": [
      {
        "type": "hint",
        "expectedToolEvents": ["hintReveal"],
        "expectedFeedbackPlans": [
          {
            "kind": "preset",
            "sourceEventType": "hintReveal",
            "feedbackPresetId": "hint_reveal",
            "toolId": "hint"
          }
        ],
        "expectedToolState": {
          "hint": {
            "usesRemaining": 2,
            "cooldownRemainingSeconds": 10
          }
        }
      },
      {
        "type": "tick",
        "deltaSeconds": 4,
        "expectedToolState": {
          "hint": {
            "cooldownRemainingSeconds": 6
          }
        },
        "expectedViewModel": {
          "hud": {
            "timer": {
              "label": "0:56"
            }
          }
        }
      }
    ]
  },
  {
    "name": "completion creates save result",
    "modeId": "hidden_object_demo",
    "steps": [
      {
        "type": "tap",
        "point": {
          "x": 330,
          "y": 860
        }
      },
      {
        "type": "tap",
        "point": {
          "x": 1330,
          "y": 1040
        }
      },
      {
        "type": "tap",
        "point": {
          "x": 480,
          "y": 1980
        }
      },
      {
        "type": "tap",
        "point": {
          "x": 1200,
          "y": 2090
        },
        "expectedRoundEvents": ["correctHit", "roundCompleted"],
        "expectedFeedbackPlans": [
          {
            "kind": "preset",
            "sourceEventType": "correctHit",
            "feedbackPresetId": "find_success",
            "targetId": "demo_gem_001"
          },
          {
            "kind": "settlement",
            "sourceEventType": "roundCompleted",
            "finalScore": 850
          }
        ]
      }
    ],
    "resultAtUnixMs": 1783492000000,
    "expectedResult": {
      "modeId": "hidden_object_demo",
      "status": "completed",
      "score": 850,
      "starRating": 3,
      "completedAtUnixMs": 1783492000000
    }
  },
  {
