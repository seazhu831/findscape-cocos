[
  {
    "name": "screen center maps to viewport center",
    "viewport": {
      "viewSize": {
        "width": 800,
        "height": 600
      },
      "mapSize": {
        "width": 1600,
        "height": 2400
      },
      "center": {
        "x": 800,
        "y": 1200
      },
      "zoom": 1,
      "minZoom": 0.5,
      "maxZoom": 2
    },
    "screenToMap": [
      {
        "screenPoint": {
          "x": 400,
          "y": 300
        },
        "expected": {
          "x": 800,
          "y": 1200
        }
      },
      {
        "screenPoint": {
          "x": 500,
          "y": 250
        },
        "expected": {
          "x": 900,
          "y": 1150
        }
      }
    ],
    "mapToScreen": [
      {
        "mapPoint": {
          "x": 900,
          "y": 1150
        },
        "expected": {
          "x": 500,
          "y": 250
        }
      }
    ]
  },
  {
    "name": "zoom changes screen to map scale",
    "viewport": {
      "viewSize": {
        "width": 800,
        "height": 600
      },
      "mapSize": {
        "width": 1600,
        "height": 2400
      },
      "center": {
        "x": 800,
        "y": 1200
      },
      "zoom": 2,
      "minZoom": 0.5,
      "maxZoom": 2
    },
    "screenToMap": [
      {
        "screenPoint": {
          "x": 500,
          "y": 300
        },
        "expected": {
          "x": 850,
          "y": 1200
        }
      }
    ]
  },
  {
    "name": "pan moves camera opposite screen drag",
    "viewport": {
      "viewSize": {
        "width": 800,
        "height": 600
      },
      "mapSize": {
        "width": 1600,
        "height": 2400
      },
      "center": {
        "x": 800,
        "y": 1200
      },
      "zoom": 1,
      "minZoom": 0.5,
      "maxZoom": 2
    },
    "pan": {
      "screenDelta": {
        "x": 80,
        "y": -40
      },
      "expectedCenter": {
        "x": 720,
        "y": 1240
      }
    }
  },
  {
    "name": "center clamps to visible map bounds",
    "viewport": {
      "viewSize": {
        "width": 800,
        "height": 600
      },
      "mapSize": {
        "width": 1600,
        "height": 2400
      },
      "center": {
        "x": 800,
        "y": 1200
      },
      "zoom": 1,
      "minZoom": 0.5,
      "maxZoom": 2
    },
    "clampCenter": {
      "center": {
        "x": 50,
        "y": 50
      },
      "expectedCenter": {
        "x": 400,
        "y": 300
      }
    }
  },
  {
    "name": "zoom at anchor preserves map point under anchor",
    "viewport": {
      "viewSize": {
        "width": 800,
        "height": 600
      },
      "mapSize": {
        "width": 1600,
        "height": 2400
      },
      "center": {
        "x": 800,
        "y": 1200
      },
      "zoom": 1,
      "minZoom": 0.5,
      "maxZoom": 2
    },
    "zoomAt": {
      "nextZoom": 2,
      "anchorScreenPoint": {
        "x": 500,
        "y": 300
      },
      "expectedCenter": {
        "x": 850,
        "y": 1200
      }
    }
  },
  {
    "name": "oversized visible axis stays centered on portrait map",
    "viewport": {
      "viewSize": {
        "width": 1200,
        "height": 800
      },
      "mapSize": {
        "width": 1600,
        "height": 2400
      },
      "center": {
        "x": 50,
        "y": 50
      },
      "zoom": 0.3333333333333333,
      "minZoom": 0.3333333333333333,
      "maxZoom": 2
    },
    "clampCenter": {
      "center": {
        "x": 50,
        "y": 50
      },
      "expectedCenter": {
        "x": 800,
        "y": 1200
      }
    }
  }
]
