        "point": {
          "x": 10,
          "y": 10
        },
        "expected": {
          "foundCount": 0,
          "score": 0,
          "isComplete": false,
          "lastFeedbackPlans": [
            {
              "kind": "preset",
              "sourceEventType": "wrongTap",
              "feedbackPresetId": "wrong_tap"
            }
          ]
        }
      },
      {
        "type": "tap",
        "point": {
          "x": 1060,
          "y": 1310
        },
        "expected": {
          "foundCount": 1,
          "score": 150,
          "isComplete": true,
          "lastFeedbackPlans": [
            {
              "kind": "preset",
