[
  {
    "name": "hidden object starts with mixed target counts and active assets",
    "modeId": "hidden_object_demo",
    "expectedInitial": {
      "selectedTargetCount": 4,
      "viewport": {
        "center": {
          "x": 800,
          "y": 1200
        },
        "zoom": 1
      },
      "targetCounts": {
        "pineapple": 2,
        "puppy": 1,
        "gem": 1
      },
      "assetStateCounts": {
        "runtimeAsset": 19
      },
      "activeAssetPaths": [
        "art/maps/demo_cozy_town_placeholder",
        "art/icons/icon_pineapple",
        "art/icons/icon_puppy",
        "art/icons/icon_gem",
        "art/targets/target_pineapple",
        "art/targets/target_puppy",
        "art/targets/target_gem",
        "art/icons/tool_hint",
        "art/icons/tool_magnifier"
      ],
      "isComplete": false
    }
  },
  {
    "name": "viewport pan and zoom preserve target hit semantics",
    "modeId": "hidden_object_demo",
    "steps": [
      {
        "type": "setViewSize",
        "viewSize": {
          "width": 1200,
          "height": 800
        },
        "expected": {
          "viewport": {
            "center": {
              "x": 800,
              "y": 1200
            },
            "zoom": 1
          }
        }
      },
      {
        "type": "pan",
        "screenDelta": {
          "x": -120,
          "y": 80
        },
        "expected": {
          "viewport": {
            "center": {
              "x": 920,
              "y": 1120
            },
            "zoom": 1
          }
        }
      },
      {
        "type": "zoom",
        "nextZoom": 1,
        "anchorScreenPoint": {
          "x": 600,
          "y": 400
        },
        "expected": {
          "viewport": {
            "center": {
              "x": 920,
              "y": 1120
            },
            "zoom": 1
          }
        }
      },
      {
        "type": "resetViewport",
        "viewSize": {
          "width": 1200,
          "height": 800
        },
        "expected": {
          "viewport": {
            "center": {
              "x": 800,
              "y": 1200
            },
            "zoom": 0.3333333333333333
          }
        }
      },
      {
        "type": "tap",
        "point": {
          "x": 330,
          "y": 860
        },
        "expected": {
          "foundCount": 1,
          "score": 100,
          "isComplete": false,
          "lastFeedbackPlans": [
            {
              "kind": "preset",
              "sourceEventType": "correctHit",
              "feedbackPresetId": "find_success",
              "targetId": "demo_pineapple_001",
              "scoreAdded": 100
            }
          ]
        }
      }
    ]
  },
  {
    "name": "balloon mode completes and ignores post-complete taps",
    "modeId": "balloon_blast_demo",
    "steps": [
      {
        "type": "tap",
        "point": {
          "x": 930,
          "y": 360
        },
        "expected": {
          "foundCount": 1,
          "score": 100,
          "isComplete": false,
          "lastFeedbackPlans": [
            {
              "kind": "preset",
              "sourceEventType": "correctHit",
              "feedbackPresetId": "pop_success",
              "targetId": "demo_balloon_001",
              "scoreAdded": 100
            }
          ]
        }
      },
      {
        "type": "tap",
        "point": {
          "x": 1170,
          "y": 1620
        },
        "expected": {
          "foundCount": 2,
          "score": 200,
          "isComplete": true,
          "lastFeedbackPlans": [
            {
              "kind": "preset",
              "sourceEventType": "correctHit",
              "feedbackPresetId": "pop_success",
              "targetId": "demo_balloon_002",
              "scoreAdded": 100
            },
            {
              "kind": "settlement",
              "sourceEventType": "roundCompleted",
              "finalScore": 200
            }
          ]
        }
      },
      {
        "type": "tap",
        "point": {
          "x": 930,
          "y": 360
        },
        "expected": {
          "foundCount": 2,
          "score": 200,
          "isComplete": true,
          "lastFeedbackPlans": []
        }
      }
    ]
  },
  {
    "name": "wrong tap applies preview penalty without going below zero",
    "modeId": "crime_hunt_demo",
