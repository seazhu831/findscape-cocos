      "status": "completed",
      "score": 200,
      "foundCount": 1,
      "totalCount": 1,
      "accuracy01": 1,
      "starRating": 3,
      "completedAtUnixMs": 1783491200000
    },
    "expectedSave": {
      "bestByModeId": {
        "crime_hunt_demo": {
          "bestScore": 200
        }
      }
    }
  },
