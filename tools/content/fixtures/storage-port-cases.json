  {
    "name": "apply result persists updated save",
    "operation": "applyResult",
    "initialStorage": {},
    "result": {
      "modeId": "hidden_object_demo",
      "status": "completed",
      "score": 850,
      "foundCount": 4,
      "totalCount": 4,
      "accuracy01": 1,
      "starRating": 3,
      "completedAtUnixMs": 1783491000000
    },
    "expectedSave": {
      "lastResult": {
        "modeId": "hidden_object_demo",
        "score": 850
      },
      "bestByModeId": {
        "hidden_object_demo": {
          "bestScore": 850,
          "bestStarRating": 3
        }
      }
    },
    "expectedStorage": {
      "findscape.localSave.v1": {
        "lastResult": {
          "modeId": "hidden_object_demo",
          "score": 850
        }
      }
    }
  },
  {
    "name": "custom storage key is honored",
    "operation": "applyResult",
    "storageKey": "custom.save",
    "initialStorage": {},
    "result": {
      "modeId": "balloon_blast_demo",
      "status": "expired",
      "score": 120,
      "foundCount": 1,
      "totalCount": 2,
      "accuracy01": 0.5,
      "starRating": 1,
      "completedAtUnixMs": 1783491100000
    },
    "expectedStorage": {
      "custom.save": {
        "lastResult": {
          "modeId": "balloon_blast_demo",
          "score": 120
        }
      }
    }
  },
  {
