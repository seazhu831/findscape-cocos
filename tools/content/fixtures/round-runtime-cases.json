[
  {
    "name": "hidden object round completes with time bonus",
    "modeId": "hidden_object_demo",
    "steps": [
      {
        "type": "tap",
        "point": {
          "x": 330,
          "y": 860
        },
        "expectedEvents": ["correctHit"],
        "expectedState": {
          "status": "playing",
          "score": 110,
          "comboStreak": 1,
          "correctHits": 1,
          "wrongTaps": 0
        }
      },
      {
        "type": "tap",
        "point": {
          "x": 1330,
          "y": 1040
        },
        "expectedEvents": ["correctHit"],
        "expectedState": {
          "status": "playing",
          "score": 230,
          "comboStreak": 2,
          "correctHits": 2,
          "wrongTaps": 0
        }
      },
      {
        "type": "tap",
        "point": {
          "x": 480,
          "y": 1980
        },
        "expectedEvents": ["correctHit"],
        "expectedState": {
          "status": "playing",
          "score": 380,
          "comboStreak": 3,
          "correctHits": 3,
          "wrongTaps": 0
        }
      },
      {
        "type": "tap",
        "point": {
          "x": 1200,
          "y": 2090
        },
        "expectedEvents": ["correctHit", "roundCompleted"],
        "expectedState": {
          "status": "completed",
          "score": 850,
          "comboStreak": 4,
          "correctHits": 4,
          "wrongTaps": 0
        }
      }
    ]
  },
  {
    "name": "wrong tap resets combo and duplicate does not score",
    "modeId": "hidden_object_demo",
    "steps": [
      {
        "type": "tap",
        "point": {
          "x": 330,
          "y": 860
        },
        "expectedEvents": ["correctHit"],
        "expectedState": {
          "score": 110,
          "comboStreak": 1,
          "correctHits": 1,
          "wrongTaps": 0
        }
      },
      {
        "type": "tap",
        "point": {
          "x": 10,
          "y": 10
        },
        "expectedEvents": ["wrongTap"],
        "expectedState": {
          "score": 110,
          "comboStreak": 0,
          "correctHits": 1,
          "wrongTaps": 1
        }
      },
      {
        "type": "tap",
        "point": {
          "x": 330,
          "y": 860
        },
        "expectedEvents": ["duplicateHit"],
        "expectedState": {
          "score": 110,
          "comboStreak": 0,
          "correctHits": 1,
          "wrongTaps": 1
        }
      }
    ]
  },
  {
    "name": "balloon mode selects only balloon targets",
    "modeId": "balloon_blast_demo",
    "expectedInitialSelectedTargets": ["demo_balloon_001", "demo_balloon_002"],
    "steps": [
      {
        "type": "tap",
        "point": {
          "x": 930,
          "y": 360
        },
        "expectedEvents": ["correctHit"],
        "expectedState": {
          "score": 110,
          "comboStreak": 1,
          "correctHits": 1
        }
      }
    ]
  },
  {
    "name": "round can expire",
    "modeId": "crime_hunt_demo",
    "steps": [
      {
        "type": "advanceTime",
        "deltaSeconds": 61,
        "expectedState": {
          "status": "expired",
          "remainingSeconds": 0
        }
      }
    ]
  },
  {
    "name": "fractional remaining time produces integer completion score",
    "modeId": "balloon_blast_demo",
    "steps": [
      {
        "type": "advanceTime",
        "deltaSeconds": 12.345,
        "expectedState": {
          "status": "playing",
          "remainingSeconds": 47.655
        }
      },
      {
        "type": "tap",
        "point": {
          "x": 930,
          "y": 360
        },
        "expectedEvents": ["correctHit"],
        "expectedState": {
          "score": 110,
          "comboStreak": 1
        }
      },
      {
        "type": "tap",
        "point": {
          "x": 1170,
          "y": 1620
        },
        "expectedEvents": ["correctHit", "roundCompleted"],
        "expectedState": {
          "status": "completed",
          "score": 468,
          "comboStreak": 2
        }
      }
    ]
  }
]
