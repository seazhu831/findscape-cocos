    {
      "toolId": "magnifier",
      "name": "Magnifier",
      "usesPerRound": 1,
      "cooldownSeconds": 15,
      "effect": "zoomArea",
      "durationSeconds": 4,
      "value": 1.5,
      "iconAsset": "art/icons/tool_magnifier"
    }
  ],
  "gameModes": [
    {
      "modeId": "hidden_object_demo",
      "name": "Hidden Object Demo",
      "description": "Find a small set of requested objects from the bottom target list.",
      "mapId": "demo_cozy_town",
      "targetSelectionRule": {
        "type": "byCategoryCounts",
        "countsByType": {
          "pineapple": 2,
          "puppy": 1,
          "gem": 1
        }
      },
      "timeLimitSeconds": 60,
      "scoringRuleId": "demo_default_scoring",
      "toolIds": ["hint", "magnifier"],
      "successRule": "findAllSelectedTargets",
      "failureRule": "timeExpired",
      "feedbackOverrides": {}
    },
    {
      "modeId": "balloon_blast_demo",
      "name": "Balloon Blast Demo",
      "description": "Pop all balloons using the same target point runtime.",
      "mapId": "demo_cozy_town",
      "targetSelectionRule": {
        "type": "allOfType",
        "typeId": "balloon"
      },
      "timeLimitSeconds": 60,
      "scoringRuleId": "demo_default_scoring",
      "toolIds": ["hint"],
      "successRule": "findAllSelectedTargets",
      "failureRule": "timeExpired",
      "feedbackOverrides": {
        "balloon": {
          "triggerBehavior": "tapToPop",
          "feedbackPresetId": "pop_success"
        }
      }
    },
    {
      "modeId": "crime_hunt_demo",
      "name": "Crime Hunt Demo",
      "description": "Catch thief targets using mode-specific copy and feedback.",
      "mapId": "demo_cozy_town",
      "targetSelectionRule": {
        "type": "allOfType",
        "typeId": "thief"
      },
      "timeLimitSeconds": 60,
      "scoringRuleId": "demo_default_scoring",
      "toolIds": ["hint"],
      "successRule": "findAllSelectedTargets",
      "failureRule": "timeExpired",
      "feedbackOverrides": {
        "thief": {
          "triggerBehavior": "tapToCatch",
          "feedbackPresetId": "catch_success"
        }
      }
    }
